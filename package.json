{
  "name": "bob",
  "version": "1.0.2",
  "description": "B.O.B. — Unified Customer Success Platform",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
    "icons": "node scripts/generate-icons.js",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "package": "npm run build && electron-builder --config.npmRebuild=true",
    "package:mac": "npm run build && electron-builder --mac --universal",
    "package:mac:x64": "npm run build && electron-builder --mac --x64",
    "package:mac:arm64": "npm run build && electron-builder --mac --arm64",
    "package:win": "npm run build && electron-builder --win",
    "dist": "npm run icons && npm run build && electron-builder --mac --universal",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "clsx": "^2.1.0",
    "electron-updater": "^6.8.3",
    "fuse.js": "^7.0.0",
    "googleapis": "^128.0.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.344.0",
    "node-cron": "^3.0.3",
    "node-llama-cpp": "^3.18.1",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "ulid": "^2.3.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^41.2.2",
    "electron-builder": "^26.9.0",
    "electron-vite": "^5.0.0",
    "sharp": "^0.33.5",
    "typescript": "^5.4.2",
    "vite": "^5.1.6"
  }
}
